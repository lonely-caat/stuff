import requests
import logging as logger
import json
from zabbix_auth import Auth
from base_request import BaseRequest


class ZabbixClient(BaseRequest):
    def __init__(self, host, payload):
        self.base = host
        self.logger = logger.getLogger()
        self.payload = payload

    def query_api(self,data):
        base = Auth()
        # import pdb;
        # pdb.set_trace()
        post_data = dict(base.get_auth_token().items()+self.payload.items())
        resp = self.make_request()

        return json.loads(resp.text), 'zabbix client'
                             # resp.status_code, resp.url


